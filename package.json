{
  "name": "eduardoos-com-backend-20260423",
  "version": "1.0.0",
  "description": "Professional backend for eduardoos.com frontend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --exclude \"./data/**\" --exclude \"**/*.db\" --exclude \"**/*.db-shm\" --exclude \"**/*.db-wal\" src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "db:generate:auth": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate:articles": "drizzle-kit generate --config drizzle.articles.config.ts",
    "db:generate": "npm run db:generate:auth && npm run db:generate:articles",
    "db:migrate:auth": "drizzle-kit migrate --config drizzle.config.ts",
    "db:migrate:articles": "drizzle-kit migrate --config drizzle.articles.config.ts",
    "db:migrate": "npm run db:migrate:auth && npm run db:migrate:articles",
    "db:push:auth": "drizzle-kit push --config drizzle.config.ts",
    "db:push:articles": "drizzle-kit push --config drizzle.articles.config.ts",
    "db:push": "npm run db:push:auth && npm run db:push:articles",
    "db:seed:biblia": "tsx scripts/seed-biblia-articles.ts",
    "db:seed:admin": "tsx scripts/seed-admin.ts",
    "db:seed:test-user": "tsx scripts/seed-test-user.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.6",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
